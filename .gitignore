# Dependencies
node_modules/

# Generated by scripts/prepare-www.js before every Capacitor command —
# never hand-edit this folder, it's regenerated from the project root
# (index.html, css/, js/, assets/) every time.
www/

# Android Studio / Gradle local files (machine-specific, not needed by
# other contributors — the rest of android/ should be committed once
# `npx cap add android` has generated it, since native customizations
# like AndroidManifest.xml edits and generated icons/splash screens
# belong in version control).
android/local.properties
android/.gradle/
android/app/build/
android/build/
android/.idea/
android/*.iml
